# Razorpay — get from https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) while developing.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret

# Set in Razorpay Dashboard → Settings → Webhooks when you add the webhook URL.
# Events to enable: payment.captured, payment.failed, refund.processed
RAZORPAY_WEBHOOK_SECRET=any_long_random_string

# One-time setup secret: the first visit to /admin/login uses this to create
# the owner account. After that it's inert (sign-in is email + password).
ADMIN_KEY=change_me_to_a_long_random_string

# Postgres connection string (e.g. Neon via Vercel Marketplace). REQUIRED —
# orders, products, customers and admin accounts all live here.
# Run `npm run db:migrate` once after setting it.
DATABASE_URL=postgres://user:pass@host/db

# ── Transactional email (Resend — https://resend.com) ──────────────────────
# Optional: without RESEND_API_KEY no emails are sent (everything else works).
# Resend's free tier (3,000/mo, 100/day) covers a launching D2C store and its
# deliverability to Indian inboxes is solid. For INR billing / India data
# residency at higher volume, Zoho ZeptoMail is the India-native alternative
# (the send layer in src/lib/notify.ts is small and easy to swap).
#
# Deliverability depends far more on domain auth than the provider: verify your
# sending domain and add the SPF, DKIM and DMARC records the provider gives you.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="EVHERFIT <orders@yourdomain.com>"   # must be on a verified domain
# SUPPORT_EMAIL=support@yourdomain.com            # Reply-To on customer emails
# ORDER_NOTIFY_EMAIL=owner@yourdomain.com         # new-order + low-stock alerts
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com     # used for links in emails
